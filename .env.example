# Configuração de Ambiente - Monitora Portarias
# Copie este arquivo para .env e configure conforme seu ambiente

# === AMBIENTE ===
# Opções: dev, prod
ENVIRONMENT=dev

# === DATABASE ===
# Dev: SQLite (sem dependências externas)
DATABASE_URL=sqlite:///./portarias.db

# Prod: PostgreSQL (descomente e configure conforme necessário)
# DATABASE_URL=postgresql://username:password@localhost:5432/portarias_db

# === FASTAPI ===
# DEBUG: ativa ou desativa modo debug
DEBUG=True

# === LOGGING ===
# Nível de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# === AUTENTICAÇÃO (Fase 2) ===
# Secret key para JWT (gerar via: python -c "import secrets; print(secrets.token_urlsafe(32))")
# SECRET_KEY=your-secret-key-here

# === CORS (Fase 2) ===
# Origens permitidas para CORS (separadas por vírgula)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
